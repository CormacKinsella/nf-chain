// Pipeline manifest
manifest {
    name            = 'cormackinsella/nf-chain'
    contributors    = [
        [
            name: 'Cormac Kinsella',
            affiliation: 'National Bioinformatics Infrastructure Sweden (NBIS), Uppsala University',
            email: 'cormac.kinsella@nbis.se',
            github: 'https://github.com/CormacKinsella',
            contribution: ['author', 'maintainer']
        ]
    ]
    homePage        = 'https://github.com/cormackinsella/nf-chain'
    description     = 'Generate chain files for genome liftovers'
    mainScript      = 'main.nf'
    defaultBranch   = 'main'
    nextflowVersion = '!>=26.4.1'
    version         = '0.1'
}

// Enable pipeline resume by default
resume = true

// Global default params
params {

    // General
    project                    = null
    steps                      = 'prepare_inputs,align_assemblies,generate_chains'

    // Input options
    input                      = null

    // Workflow settings
    aligner                    = null
    softmask_source            = false
    softmask_target            = false

    // Chunking general
    chunk_size                 = 4500 // FASTA records have this size
    extra                      = 500  // FASTA records overlap by this many bases

    // BLAT specific
    aggregate_chunk_size       = 10000000 // FASTA records are aggregated into sets of this size for BLAT alignment
    exclude_frequent_kmers     = true     // Frequent 11-mers are masked by BLAT
    blat_mask_lower_in_target  = true     // BLAT considers lowercase softmasking in the target assembly (BLAT query)
    blat_mask_lower_in_source  = true     // BLAT considers lowercase softmasking in the source assembly (BLAT target_reference)
    blat_fastmap               = true     // Use BLAT's fastMap option (reduces sensitivity, so use for close assemblies only)
    blat_min_score             = 100      // Set after UCSC default (BLAT default 30)
    blat_min_identity          = 95       // UCSC default 98, BLAT default 90

    // Internal
    outdir                     = 'results'
    monochrome_logs            = false
    help                       = false
    help_full                  = false
    show_hidden                = false
    version                    = false
    trace_timestamp            = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
    tracing                    = false
    validate_params            = true
    config_profile_name        = null
    config_profile_description = null
    config_profile_contact     = null
    config_profile_url         = null
    custom_config_version      = 'master'
    custom_config_base         = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"

}

// Generic HPC config, override with specific profiles
includeConfig 'conf/base.config'

// Profiles
profiles {
    debug {
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    docker {
        docker.enabled          = true
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    emulate_amd64 {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        apptainer.cacheDir      = "work/singularity"
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        singularity.cacheDir    = "work/singularity"
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// Allow institutional configs
includeConfig params.custom_config_base && (!System.getenv('NXF_OFFLINE') || !params.custom_config_base.startsWith('http')) ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

// Set container registry information
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

// Bash options
process.shell = [
    "bash",
    "-C",           // No clobber - prevent output redirection from overwriting files.
    "-e",           // Exit if a tool returns a non-zero status/exit code
    "-u",           // Treat unset variables and parameters as an error
    "-o",           // Returns the status of the last command to exit..
    "pipefail"      //   ..with a non-zero status or zero if all successfully execute
]

// Universal output publishing settings
workflow {
    output {
        mode = 'copy'
        overwrite = true
    }
}

// Disable process selector warnings (use debug profile to enable)
nextflow.enable.configProcessNamesValidation = false

// Tracing
timeline {
    enabled   = params.tracing
    file      = "${projectDir}/results/01_pipeline_info/tracing/${params.trace_timestamp}_timeline.html"
    overwrite = true
}
report {
    enabled   = params.tracing
    file      = "${projectDir}/results/01_pipeline_info/tracing/${params.trace_timestamp}_report.html"
    overwrite = true
}
trace {
    enabled   = params.tracing
    file      = "${projectDir}/results/01_pipeline_info/tracing/${params.trace_timestamp}_trace.txt"
    overwrite = true
}
dag {
    enabled   = params.tracing
    file      = "${projectDir}/results/01_pipeline_info/tracing/${params.trace_timestamp}_dag.png"
    overwrite = true
}

// Plugins & validation
plugins {
    id 'nf-schema@2.6.1'
}

// Do not prompt updates to specific parameter defaults when running `nf-core pipelines schema build`
validation {
    defaultIgnoreParams = [
        "trace_timestamp"
    ]
}

// Modules config
includeConfig 'conf/modules.config'

// Tool resources
includeConfig 'conf/tool_resources.config'
