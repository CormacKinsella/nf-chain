// Test config for tiny dataset

process {

    executor = 'local'
    cpus     = 1
    memory   = 6.GB
    time     = 10.m

    resourceLimits = [
        cpus: 16,
        memory: 20.GB,
        time: 4.h
    ]

    withLabel:process_single {
        cpus   = 1
        memory = 2.GB
        time   = 1.h
    }
    withLabel: process_low {
        cpus   = 2
        memory = 4.GB
        time   = 4.h
    }
    withLabel: process_medium {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }
    withLabel: process_high {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }
    withLabel: process_long {
        time   = 4.h
    }
    withLabel: process_high_memory {
        memory = 20.GB
        time   = 4.h
    }

}
